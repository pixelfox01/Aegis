# Database Configuration
POSTGRES_PASSWORD=changeme_secure_password

# JWT Secret for Authentication (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=changeme_random_secret_key

# Authentication Mode: "local" for simple username/password, "auth0" for Auth0
AUTH_MODE=local

# Auth0 Configuration (only required if AUTH_MODE=auth0)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id

# LLM Provider: "gemini" or "ollama"
LLM_PROVIDER=gemini

# Gemini API Configuration (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key

# Ollama Configuration (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Backboard API (optional)
BACKBOARD_API_KEY=your_backboard_api_key
